# ── Core ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://layoutlab.com

# ── Database (Vercel Postgres) ──────────────────────────────────────────
DATABASE_URL=

# ── Auth.js (NextAuth v5) ───────────────────────────────────────────────
AUTH_SECRET=
AUTH_URL=http://localhost:3000

# ── Stripe ──────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

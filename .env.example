# ── Core ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://divi5lab.com
# GA4 Measurement ID (public, safe to expose). Optional — defaults to the prod tag in code.
NEXT_PUBLIC_GA_ID=G-YCK6MN99PR

# ── Database (Vercel Postgres) ──────────────────────────────────────────
DATABASE_URL=

# ── Auth.js (NextAuth v5) ───────────────────────────────────────────────
AUTH_SECRET=
# Base URL for auth redirects/callbacks. Local: http://localhost:3000.
# PRODUCTION (Vercel) MUST be your real domain, e.g. https://divi5lab.com — a
# stale localhost value here makes prod sign-in links point to localhost.
AUTH_URL=http://localhost:3000
# Comma-separated emails granted the admin role (Phase 2 allowlist).
# Also the delivery inbox for contact-form messages (and download notifications).
ADMIN_EMAILS=

# ── Stripe ──────────────────────────────────────────────────────────────
# Acceptance walkthrough (Stripe test mode, requires Stripe CLI + local DB):
#
#   1. Create pack Products/Prices and seed membership Price IDs:
#        npm run stripe:setup
#      Then manually create monthly + yearly membership Prices in the Stripe
#      dashboard and add their IDs below.
#
#   2. Forward webhooks (copy the printed whsec_... into .env.local):
#        stripe listen --forward-to localhost:3000/api/stripe/webhook
#
#   3. Start the app and exercise the flow:
#        npm run dev
#      Open /pricing or a pack page → Buy → pay with card 4242 4242 4242 4242.
#      checkout.session.completed fires → webhook provisions the user and grants
#      the entitlement. Verify in DB:
#        docker exec layoutlab-db psql -U layoutlab -d layoutlab -c \
#          "select u.email, e.scope, e.source from entitlements e
#           join users u on u.id=e.user_id order by e.granted_at desc limit 5;"
#      Expect a pack:<id> row (pack purchase) or all_access (membership).
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_PRICE_MEMBERSHIP_MONTHLY=
STRIPE_PRICE_MEMBERSHIP_YEARLY=
# Set to 1 to require an express "immediate delivery / no refund" consent checkbox
# at Checkout (lawful basis for denying refunds to EU/UK buyers). REQUIRES a Terms
# of Service URL set in the Stripe Dashboard (Settings → Public details) pointing at
# https://divi5lab.com/license. Leave blank until that URL is configured.
STRIPE_TERMS_CONSENT=

# ── Storage (Vercel Blob) ───────────────────────────────────────────────
BLOB_READ_WRITE_TOKEN=

# ── Email ───────────────────────────────────────────────────────────────
RESEND_API_KEY=
RESEND_FROM=onboarding@resend.dev
LOOPS_API_KEY=

# ── Ingest seam (pipeline ↔ web app) ────────────────────────────────────
INGEST_API_TOKEN=

# ── Pipeline only (local / CI — NOT in the web app's Vercel runtime) ────
ANTHROPIC_API_KEY=
# How the pipeline invokes the deterministic validator (CLAUDE.md §9, Option A: CLI).
# Points at the sibling validator repo's PHP entry; the file path is appended.
VALIDATOR_CMD=php "../Divi 5 Deterministic Validator/scripts/validate.php"
# Path to the sibling validator repo (used by loadGrounding + validate.ts).
VALIDATOR_DIR=../Divi 5 Deterministic Validator
# Web app base URL for the ingest API (pipeline → web app).
INGEST_URL=http://localhost:3000
# Per-LLM-call budget cap in USD (applied to generate + each repair attempt + SEO; default: 1).
# Effective run cost ≈ cap × (2–4 LLM calls per layout) × number of target combinations.
PIPELINE_MAX_BUDGET_USD=1
WP_RENDER_BASE_URL=http://localhost:8080
# Max hamming distance (out of the 256-bit perceptual/dHash — 64 hex chars,
# 4 bits each) for two rendered layouts to be treated as near-duplicates and
# dropped before ingest (T1.2). Default (20) preserves the workorder's intended
# ~8% selectivity (5/64 bits) scaled to the actual 256-bit hash space; it has
# NOT yet been tuned against a real corpus of near-dupe pairs — revisit once
# real render data is available (see pipeline/dedupe.ts).
PERCEPTUAL_DUPE_MAX_DISTANCE=20
# Visual QA gate (T1.3) — since ingest auto-publishes with no human review, this
# critic call (via the `claude` CLI, scoring rendered screenshots against a
# premium-quality rubric) IS the quality gate for render defects. Layouts
# scoring below this are dropped before ingest.
VISION_CRITIC_MIN_SCORE=3
# Optional cheaper/different model for the vision-critic call specifically
# (defaults to whatever --model the CLI uses when unset, i.e. PIPELINE_MODEL).
VISION_CRITIC_MODEL=
# Model the pipeline's `claude` CLI calls use (generation/repair/SEO/critic);
# unset uses the CLI's own default.
PIPELINE_MODEL=
# Bounded retry-with-backoff for transient infra failures (network/CLI/upload/
# ingest blips) at the per-target level (T2.2) — never applied to permanent
# failures (usage-limit/budget/auth/unrecognized), which fail immediately.
# Max retries per target (default 2, i.e. up to 3 total attempts).
PIPELINE_RETRY_MAX=2
# Base backoff delay in ms; doubled each retry (default 250 → 250ms, 500ms, ...).
PIPELINE_RETRY_BASE_DELAY_MS=250
# SEO quality floor (T2.4) — pipeline/seo.ts retries the SEO call ONCE if the
# model's metaDescription/keywords don't meet these minimums; still unmet after
# the retry is logged + flagged via a `seo_floor_miss` RunEvent, never dropped.
SEO_MIN_META_DESCRIPTION_LENGTH=70
SEO_MIN_KEYWORDS=3
# Image relevance gate (T5.2) — the SAME vision-critic call (VISION_CRITIC_MIN_SCORE
# above) also rates whether visible photos match the section's niche/subject (e.g. a
# dental-clinic hero must not show a car). FLAG-ONLY: a below-threshold score is
# logged + reported via an `image_relevance` RunEvent, never dropped or re-resolved —
# see pipeline/vision-critic.ts's `meetsImageRelevanceBar` and pipeline/run.ts.
IMAGE_RELEVANCE_MIN_SCORE=3
# Copy-quality gate (T5.1) — the SAME vision-critic call also scores generated prose
# (headlines/body/CTAs) for genericness/AI-tell-tale phrasing. FLAG-ONLY like
# IMAGE_RELEVANCE_MIN_SCORE above: a below-threshold score is logged + reported via a
# `copy_critic` RunEvent, never dropped — see pipeline/deps.ts's copyCriticMinScore
# wiring and pipeline/run.ts.
COPY_CRITIC_MIN_SCORE=3
# Boilerplate/near-duplicate-copy gate (T5.1) — deterministic (no LLM call): 5-word
# shingle overlap between a new section's extracted prose and every other section's
# prose already accepted THIS RUN. Above this overlap ratio (0-1) the layout is
# DROPPED before ingest (unlike the two critic scores above, this one is a hard gate,
# not flag-only) — see pipeline/copy-critic.ts's DEFAULT_COPY_BOILERPLATE_MAX_OVERLAP
# and copyBoilerplateMaxOverlap(). NOT yet tuned against a real corpus of
# near-duplicate copy — revisit once real generation runs accumulate data (see
# docs/superpowers/specs/2026-07-07-generator-hardening-followups.md).
COPY_BOILERPLATE_MAX_OVERLAP=0.5

# Real-corpus few-shot retrieval (T3.4) — see pipeline/library/exemplars.ts. Injects
# real, validated Divi 5 section markup (from the converted public/layout-library-json
# corpus) into the generation prompt so Claude imitates real structure instead of
# free-inventing it. Set to 0 to disable and A/B against the curated-recipes-only path
# (RECIPE_BY_TYPE in pipeline/recipes/prompts.ts).
USE_LIBRARY_EXEMPLARS=1
# How many ranked exemplars (BM25 over the target's type/niche/style/directive terms,
# within the target type's mapped corpus "kind" — see KIND_BY_TYPE) to inject per
# generation prompt (default 2).
LIBRARY_EXEMPLAR_K=2
# Per-exemplar character cap (default 6000) — keeps a single verbose real section
# (e.g. a long pricing-table markup) from blowing out prompt size; the retrieval
# pool falls back to the smallest real instance(s) of a kind if NONE fit under the
# cap, rather than injecting nothing (see getLibraryExemplars in exemplars.ts).
LIBRARY_EXEMPLAR_MAXCHARS=6000

# Prompt-caching layout (T1.4) — moves the ~20KB stable grounding block (Divi 5
# schema/style guide/curated recipe examples for a target's TYPE) into the CLI's
# `--append-system-prompt`, which is byte-identical across every call sharing a type
# and therefore cache-eligible; only the genuinely target-specific ask (niche/style/
# directives/retrieved library exemplars) stays in the varying user prompt. Set to 0
# to revert to the pre-T1.4 layout (grounding inlined in the user prompt on every
# call) — the A/B escape hatch for scripts/eval-generator.ts to empirically compare
# validator pass-rate/cost between the two layouts before trusting the default.
PROMPT_GROUNDING_IN_SYSTEM=1

# Stock image APIs (pipeline image resolution — server-only)
PEXELS_API_KEY=
UNSPLASH_ACCESS_KEY=
UNSPLASH_SECRET_KEY=

# ── Core ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://divi5lab.com
# GA4 Measurement ID (public, safe to expose). Optional — defaults to the prod tag in code.
NEXT_PUBLIC_GA_ID=G-YCK6MN99PR

# ── Database (Vercel Postgres) ──────────────────────────────────────────
DATABASE_URL=

# ── Auth.js (NextAuth v5) ───────────────────────────────────────────────
AUTH_SECRET=
# Base URL for auth redirects/callbacks. Local: http://localhost:3000.
# PRODUCTION (Vercel) MUST be your real domain, e.g. https://divi5lab.com — a
# stale localhost value here makes prod sign-in links point to localhost.
AUTH_URL=http://localhost:3000
# Comma-separated emails granted the admin role (Phase 2 allowlist).
# Also the delivery inbox for contact-form messages (and download notifications).
ADMIN_EMAILS=

# ── Stripe ──────────────────────────────────────────────────────────────
# Acceptance walkthrough (Stripe test mode, requires Stripe CLI + local DB):
#
#   1. Create pack Products/Prices and seed membership Price IDs:
#        npm run stripe:setup
#      Then manually create monthly + yearly membership Prices in the Stripe
#      dashboard and add their IDs below.
#
#   2. Forward webhooks (copy the printed whsec_... into .env.local):
#        stripe listen --forward-to localhost:3000/api/stripe/webhook
#
#   3. Start the app and exercise the flow:
#        npm run dev
#      Open /pricing or a pack page → Buy → pay with card 4242 4242 4242 4242.
#      checkout.session.completed fires → webhook provisions the user and grants
#      the entitlement. Verify in DB:
#        docker exec layoutlab-db psql -U layoutlab -d layoutlab -c \
#          "select u.email, e.scope, e.source from entitlements e
#           join users u on u.id=e.user_id order by e.granted_at desc limit 5;"
#      Expect a pack:<id> row (pack purchase) or all_access (membership).
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_PRICE_MEMBERSHIP_MONTHLY=
STRIPE_PRICE_MEMBERSHIP_YEARLY=
# Set to 1 to require an express "immediate delivery / no refund" consent checkbox
# at Checkout (lawful basis for denying refunds to EU/UK buyers). REQUIRES a Terms
# of Service URL set in the Stripe Dashboard (Settings → Public details) pointing at
# https://divi5lab.com/license. Leave blank until that URL is configured.
STRIPE_TERMS_CONSENT=

# ── Storage (Vercel Blob) ───────────────────────────────────────────────
BLOB_READ_WRITE_TOKEN=

# ── Email ───────────────────────────────────────────────────────────────
RESEND_API_KEY=
RESEND_FROM=onboarding@resend.dev
LOOPS_API_KEY=

# ── Ingest seam (pipeline ↔ web app) ────────────────────────────────────
INGEST_API_TOKEN=

# ── Pipeline only (local / CI — NOT in the web app's Vercel runtime) ────
ANTHROPIC_API_KEY=
# How the pipeline invokes the deterministic validator (CLAUDE.md §9, Option A: CLI).
# Points at the sibling validator repo's PHP entry; the file path is appended.
VALIDATOR_CMD=php "../Divi 5 Deterministic Validator/scripts/validate.php"
# Path to the sibling validator repo (used by loadGrounding + validate.ts).
VALIDATOR_DIR=../Divi 5 Deterministic Validator
# Web app base URL for the ingest API (pipeline → web app).
INGEST_URL=http://localhost:3000
# Per-LLM-call budget cap in USD (applied to generate + each repair attempt + SEO; default: 1).
# Effective run cost ≈ cap × (2–4 LLM calls per layout) × number of target combinations.
PIPELINE_MAX_BUDGET_USD=1
WP_RENDER_BASE_URL=http://localhost:8080
# Max hamming distance (out of the 64-hex-char perceptual/dHash) for two rendered
# layouts to be treated as near-duplicates and dropped before ingest (T1.2).
PERCEPTUAL_DUPE_MAX_DISTANCE=5

# Stock image APIs (pipeline image resolution — server-only)
PEXELS_API_KEY=
UNSPLASH_ACCESS_KEY=
UNSPLASH_SECRET_KEY=

# ── Email ───────────────────────────────────────────────────────────────
RESEND_API_KEY=
LOOPS_API_KEY=

# ── Ingest seam (pipeline ↔ web app) ────────────────────────────────────
INGEST_API_TOKEN=

# ── Pipeline only (local / CI — NOT in the web app's Vercel runtime) ────
